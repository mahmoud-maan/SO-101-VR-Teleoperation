# =============================================================================
# Godot 4
# =============================================================================

# Godot-generated import cache and shader/script cache (regenerated on open)
.godot/

# Android export template — regenerated by Godot via Project > Install Android
# Build Template (1.1 GB, should never be committed)
android/build/

# GodotOpenXRVendors plugin compiled binaries (.aar, .so, .dll)
# Install via the Godot Asset Library: "Godot OpenXR Vendors"
addons/godotopenxrvendors/.bin/

# Exported binaries / APKs
*.apk
*.aab
*.apk.delta

# =============================================================================
# ROS 2 / colcon
# =============================================================================

# colcon build output — regenerated with `colcon build`
ros2_ws/build/
ros2_ws/install/
ros2_ws/log/

# Python byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/

# =============================================================================
# General
# =============================================================================

# macOS metadata
.DS_Store

# JetBrains / VS Code local settings (keep .vscode/settings.json if you want)
.idea/
*.swp
*.swo
